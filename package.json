{
  "name": "m9terminal",
  "version": "1.0.0",
  "description": "M9 Terminal — Sports Market Intelligence Platform",
  "main": "backend/index.js",
  "scripts": {
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "nodemon backend/index.js",
    "frontend:dev": "react-scripts start",
    "build": "npm run frontend:build",
    "frontend:build": "cd frontend && npm install && npm run build && cd ..",
    "start": "node backend/index.js",
    "heroku-postbuild": "npm run build",
    "railway-build": "npm run build",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:int": "jest --testPathPattern=integration",
    "lint": "eslint backend frontend/src",
    "format": "prettier --write \"backend/**/*.js\" \"frontend/src/**/*.js\"",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/migrate-db.js",
    "db:seed": "node scripts/seed-db.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "express-rate-limit": "^7.1.5",
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.3",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "react-scripts": "5.0.1",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "jest": "^29.7.0",
    "@testing-library/react": "^14.1.2",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "author": "Oddsify Labs",
  "license": "MIT"
}
