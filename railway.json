{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm run build && node backend/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "healthcheckPath": "/health",
    "healthcheckTimeout": 10
  },
  "variables": {
    "PORT": {
      "description": "Server port (default: 3000)",
      "value": "3000"
    },
    "NODE_ENV": {
      "description": "Node environment",
      "value": "production"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL connection string",
      "required": true
    },
    "FRONTEND_URL": {
      "description": "Frontend URL for CORS (Railway will auto-set to deployment domain)",
      "required": false
    },
    "ODDS_API_KEY": {
      "description": "The Odds API key (get one free at https://the-odds-api.com)",
      "required": true
    },
    "CLAUDE_API_KEY": {
      "description": "Anthropic Claude API key (get one at https://console.anthropic.com)",
      "required": true
    },
    "SPORTSDATA_IO_API_KEY": {
      "description": "SportsData.io API key for live sport data",
      "required": false
    }
  }
}
